# macOS
.DS_Store

# Shared dotfiles - user data
users/shared/dotfiles/.direnv/
users/shared/dotfiles/.netrc
users/shared/dotfiles/.ssh/*
!users/shared/dotfiles/.ssh/allowed_signers

# Shared dotfiles - device-specific (created by home-manager / systemd)
users/shared/dotfiles/.config/environment.d/
users/shared/dotfiles/.config/fontconfig/
users/shared/dotfiles/.config/systemd/

# Pi agent
users/shared/dotfiles/.pi/agent/auth.json
users/shared/dotfiles/.pi/agent/settings.json
users/shared/dotfiles/.pi/agent/sessions/
users/shared/dotfiles/.pi/agent/bin/

